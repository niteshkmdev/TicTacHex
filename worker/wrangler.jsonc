{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "tictachex-matchmaking",
	"main": "src/worker.js",
	"compatibility_date": "2026-03-01",
	"observability": {
		"enabled": true
	},
	"durable_objects": {
		"bindings": [
			{
				"name": "MATCHMAKER",
				"class_name": "Matchmaker"
			}
		]
	},
	"migrations": [
		{
			"tag": "v1",
			"new_sqlite_classes": [
				"Matchmaker"
			]
		}
	],
	"compatibility_flags": [
		"nodejs_compat"
	]
}
